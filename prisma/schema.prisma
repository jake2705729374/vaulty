// Journal App — Prisma Schema
// Entries are stored as ciphertext only. Plaintext never reaches the server.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String    // bcrypt hash of master password
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  entries       Entry[]
  moodLogs      MoodLog[]
  sessions      Session[]
  preferences   UserPreferences?
}

// Journal entries — ciphertext only, never plaintext
model Entry {
  id         String   @id @default(cuid())
  userId     String
  title      String   // stored as plaintext (non-sensitive)
  ciphertext String   // AES-256 encrypted entry body
  iv         String   // initialisation vector (base64)
  salt       String   // PBKDF2 salt (base64)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  moodLog    MoodLog?

  @@index([userId, createdAt])
}

// Mood logged per entry (1:1)
model MoodLog {
  id        String   @id @default(cuid())
  userId    String
  entryId   String   @unique
  mood      Mood
  note      String?  // optional short note (plaintext)
  loggedAt  DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  entry     Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([userId, loggedAt])
}

enum ColorTheme {
  PARCHMENT
  SLATE
  ROSE
  FOREST
  MIDNIGHT
}

enum DarkMode {
  SYSTEM
  LIGHT
  DARK
}

model UserPreferences {
  id          String     @id @default(cuid())
  userId      String     @unique
  displayName String?
  colorTheme  ColorTheme @default(PARCHMENT)
  darkMode    DarkMode   @default(SYSTEM)
  updatedAt   DateTime   @updatedAt

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Mood {
  GREAT
  GOOD
  OKAY
  LOW
  AWFUL
}

// NextAuth sessions
model Session {
  id           String   @id @default(cuid())
  userId       String
  sessionToken String   @unique
  expires      DateTime

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
